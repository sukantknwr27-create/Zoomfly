# ============================================================
# ZoomFly — Environment Variable Template
# Copy to `.env` for local dev (never commit the real `.env`).
# Production values go in Vercel + Supabase project settings,
# NOT in this repo.
# ============================================================

# ── Vercel (api/config.js) ──────────────────────────────────
# Public Razorpay key ID (safe to expose to the browser)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ── Supabase Edge Functions ──────────────────────────────────
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are usually auto-injected
# by Supabase, but list them here for local `supabase functions serve`.)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__SECRET_NEVER_COMMIT__

# Razorpay secret key — server-side only, never in frontend code
RAZORPAY_KEY_SECRET=__SECRET_NEVER_COMMIT__

# Razorpay webhook signing secret (from Razorpay Dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=__SECRET_NEVER_COMMIT__

# Transactional email (Resend)
RESEND_API_KEY=__SECRET_NEVER_COMMIT__
FROM_EMAIL=bookings@zoomfly.in
ADMIN_EMAIL=admin@zoomfly.in
