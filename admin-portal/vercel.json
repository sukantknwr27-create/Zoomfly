{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "^/$",              "dest": "/pages/admin-login.html" },
    { "src": "^/login$",         "dest": "/pages/admin-login.html" },
    { "src": "^/dashboard$",     "dest": "/pages/admin.html" },
    { "src": "^/bookings$",      "dest": "/pages/admin-bookings.html" },
    { "src": "^/agents$",        "dest": "/pages/admin-agents.html" },
    { "src": "^/vendors$",       "dest": "/pages/admin-vendors.html" },
    { "src": "^/workflow$",      "dest": "/pages/admin-workflow.html" },
    { "src": "^/reminders$",     "dest": "/pages/admin-reminders.html" },
    { "src": "^/packages$",      "dest": "/pages/admin-packages.html" },
    { "src": "^/customers$",     "dest": "/pages/admin-customers.html" },
    { "src": "^/hotels$",        "dest": "/pages/admin-hotels.html" },
    { "src": "^/whatsapp$",      "dest": "/pages/admin-whatsapp-templates.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",            "dest": "/pages/admin-login.html" }
  ]
}
